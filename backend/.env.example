# ─────────────────────────────────────────────────────────────────────────────
# Omni Copilot — Backend Environment Configuration
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=omnicopilot

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_SECRETS_TOKEN_HEX_32

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_USE_FERNET_GENERATE_KEY

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── CORS / URLs ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Cookie security ───────────────────────────────────────────────────────────
# Set COOKIE_SECURE=False for local HTTP dev; True for production HTTPS
COOKIE_SECURE=False
COOKIE_SAMESITE=lax
