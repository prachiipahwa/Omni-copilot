# Groq LLM — https://console.groq.com
GROQ_API_KEY=

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local:
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
# Production (set this in your backend host env vars):
# GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/auth/google/callback

# Frontend URL (used for OAuth redirect back after login)
# Local:
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://omni-copilot-aic9.vercel.app

# Notion — https://www.notion.so/my-integrations
NOTION_TOKEN=

# Port (optional — defaults to 3001, Render sets this automatically)
# PORT=3001
